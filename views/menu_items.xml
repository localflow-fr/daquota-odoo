<odoo>
    <record id="action_browse_json_data" model="ir.actions.act_window">
        <field name="name">JSON Data</field>
        <field name="res_model">fr.localflow.json_data</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_browse_geodata" model="ir.actions.act_window">
        <field name="name">GeoData</field>
        <field name="res_model">fr.localflow.geodata</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_open_localflow_url" model="ir.actions.act_url">
        <field name="name">Open LocalFlow</field>
        <field name="url">/daquota_app_launcher/redirect?app_name=LocalFlow_Maps</field>
        <field name="target">new</field>
    </record>

    <menuitem id="localflow_root_menu"
              name="LocalFlow"
              sequence="10"/>

    <menuitem id="menu_json_data_item"
              name="Browse JSON Data"
              parent="localflow_root_menu"
              action="action_browse_json_data"
              sequence="10"/>

    <menuitem id="menu_geodata_item"
              name="Browse GeoData"
              parent="localflow_root_menu"
              action="action_browse_geodata"
              sequence="20"/>

    <menuitem id="menu_url_redirect_item"
              name="Open LocalFlow"
              parent="localflow_root_menu"
              action="action_open_localflow_url"
              sequence="30"/>
</odoo>
