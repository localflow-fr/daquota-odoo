<?xml version="1.0" encoding="utf-8"?>
<odoo>    
    
    <record id="action_open_lfmaps" model="ir.actions.act_url">
        <field name="name">LocalFlow Maps</field>
        <field name="type">ir.actions.act_url</field>
        <field name="url">/daquota_app_launcher/redirect?app_name=Daquota_Maps</field>
        <field name="target">new</field>
